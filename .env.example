NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/cd-store

JWT_SECRET=your-secret-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

SEPAY_MERCHANT_ID=123
SEPAY_SECRET_KEY=YOUR_SEPAY_API_KEY

FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# JWT Expiration Configurations (default: 1d = 24h, maxAge in ms: 86400000 = 24h)
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=1d
JWT_REFRESH_COOKIE_MAX_AGE=86400000
